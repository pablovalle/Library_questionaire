{
    "atomic_library": [
        {
            "id": "open",
            "description": "Actuate a mechanism to open it (door, cabinet, drawer, appliance door).",
            "parameters": [
                "joint_id"
            ],
            "pre_conditions": [
                "[joint_id] is in state: closed"
            ],
            "post_conditions": [
                "[joint_id] is in state: open"
            ]
        },
        {
            "id": "close",
            "description": "Actuate a mechanism to close it (door, cabinet, drawer, appliance door).",
            "parameters": [
                "joint_id"
            ],
            "pre_conditions": [
                "[joint_id] is in state: open"
            ],
            "post_conditions": [
                "[joint_id] is in state: closed"
            ]
        },
        {
            "id": "turn_on",
            "description": "Activate an electrical device or appliance (e.g., stove, microwave).",
            "parameters": [
                "appliance_id"
            ],
            "pre_conditions": [
                "appliance_id is in state: off"
            ],
            "post_conditions": [
                "appliance_id is in state: on"
            ]
        },
        {
            "id": "pick_up",
            "description": "Approach, grasp, and lift an object.",
            "parameters": [
                "obj_id"
            ],
            "pre_conditions": [
                "[obj_id] is at rest and not grasped"
            ],
            "post_conditions": [
                "[obj_id] is lifted from support"
            ]
        },
        {
            "id": "place",
            "description": "Lower and release a held object onto or into a target location/object, ensuring it is securely positioned without further adjustment needed.",
            "parameters": [
                "obj_id",
                "target_id"
            ],
            "pre_conditions": [
                "target_id is accessible"
            ],
            "post_conditions": [
                "[obj_id] is supported by [target_id]"
            ]
        }
    ]
}